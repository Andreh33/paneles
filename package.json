{
  "name": "panelex-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:products": "tsx scripts/validate-products.ts",
    "lighthouse": "npx --yes lighthouse http://localhost:3000 --preset=desktop --output=html --output-path=./lighthouse-report.html --view --chrome-flags=\"--headless\"",
    "lighthouse:mobile": "npx --yes lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-mobile.html --view --chrome-flags=\"--headless\""
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.76.0",
    "resend": "^6.12.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
