# ===== Panelex — variables de entorno =====
# Copia este archivo a .env.local y rellena.

# WhatsApp del comercial (sin "+" ni espacios)
NEXT_PUBLIC_WHATSAPP_NUMBER=34678978111

# Resend (formulario de contacto). Opcional: si no hay key, el form cae a mailto/WhatsApp.
RESEND_API_KEY=
RESEND_FROM_EMAIL=web@panelex.es
LEAD_DESTINATION_EMAIL=info@panelex.es

# Analítica (deshabilitada al lanzamiento — se activa cuando el cliente decida)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=panelex.es
